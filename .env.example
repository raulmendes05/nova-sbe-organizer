# Supabase — copia este ficheiro para .env.local e preenche
# (no dashboard do Supabase: Project Settings -> API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Cláudio (assistente) — chave da API do Google Gemini (aistudio.google.com/apikey)
# SEM prefixo VITE_ (fica só no servidor, nunca no browser).
GEMINI_API_KEY=...

# Provas antigas — Cloudflare R2 (dash.cloudflare.com -> R2 -> Manage API tokens)
# Guarda os PDFs. 10 GB grátis e, ao contrário do Supabase, sem custo de saída
# de dados — que é o que conta numa biblioteca só de descarregamentos.
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=exams

# Só para a importação em massa (scripts/import-exams.mjs). NUNCA no browser:
# a service role key ignora as regras de RLS.
SUPABASE_SERVICE_ROLE_KEY=...
IMPORT_AS_EMAIL=o.teu.email@novasbe.pt
